{
  "Comment": "Gasclaw Management Dashboard CloudFront Distribution",
  "DistributionConfig": {
    "CallerReference": "gasclaw-dashboard-2026-03-25",
    "Aliases": {
      "Quantity": 1,
      "Items": ["status.gpu.villamarket.ai"]
    },
    "DefaultRootObject": "index.html",
    "Origins": {
      "Quantity": 1,
      "Items": [
        {
          "Id": "DashboardOrigin",
          "DomainName": "gpu-workspace.taile8dc37.ts.net",
          "OriginPath": "/status",
          "CustomOriginConfig": {
            "HTTPPort": 80,
            "HTTPSPort": 443,
            "OriginProtocolPolicy": "https-only",
            "OriginSslProtocols": {
              "Quantity": 1,
              "Items": ["TLSv1.2"]
            }
          }
        }
      ]
    },
    "DefaultCacheBehavior": {
      "TargetOriginId": "DashboardOrigin",
      "ViewerProtocolPolicy": "https-only",
      "CachePolicyId": "4135ea2d-6df8-44a3-9df3-4b5a84be39ad",
      "OriginRequestPolicyId": "b689b0a8-53d0-40ab-baf2-68738e2966ac"
    },
    "PriceClass": "PriceClass_100",
    "Enabled": true,
    "ViewerCertificate": {
      "ACMCertificateArn": "arn:aws:acm:us-east-1:914499832220:certificate/c88709b4-388b-4462-9eb7-4c60a519a21e",
      "SSLSupportMethod": "sni-only",
      "MinimumProtocolVersion": "TLSv1.2_2021"
    }
  }
}
